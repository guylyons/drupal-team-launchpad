# Normalize text files for consistent diffs across macOS/Linux/Windows.
* text=auto eol=lf

# Shell scripts must keep LF endings.
*.sh text eol=lf
*.bash text eol=lf

# Drupal/PHP/config/text assets.
*.php text eol=lf
*.module text eol=lf
*.install text eol=lf
*.inc text eol=lf
*.theme text eol=lf
*.profile text eol=lf
*.twig text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.json text eol=lf
*.md text eol=lf
*.css text eol=lf
*.scss text eol=lf
*.js text eol=lf
*.ts text eol=lf

# Binary assets.
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.webp binary
*.ico binary
*.pdf binary
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary
*.zip binary
*.gz binary
*.mp4 binary
*.mov binary
