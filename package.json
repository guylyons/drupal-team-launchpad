{
  "name": "drupal-team",
  "private": true,
  "license": "MIT",
  "type": "module",
  "packageManager": "pnpm@9.15.4",
  "engines": {
    "node": ">=22 <27",
    "pnpm": ">=9 <10"
  },
  "scripts": {
    "format": "prettier --write . && composer format:php",
    "format:check": "prettier --check .",
    "format:php": "composer format:php",
    "lint": "pnpm format:check && composer lint:php",
    "lint:php": "composer lint:php"
  },
  "devDependencies": {
    "@prettier/plugin-php": "^0.22.4",
    "prettier": "^3.4.2",
    "prettier-plugin-twig-melody": "^0.4.6"
  }
}
