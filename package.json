{
  "name": "drupal-team",
  "private": true,
  "license": "MIT",
  "type": "module",
  "packageManager": "pnpm@9.15.4",
  "engines": {
    "node": ">=22 <27",
    "pnpm": ">=9 <10"
  },
  "scripts": {
    "setup": "./scripts/dev",
    "dev": "./scripts/dev --ddev",
    "check": "pnpm format:check && composer validate --no-check-publish && composer lint:php",
    "agent:next": "./scripts/hermes-command next",
    "hermes:check": "./scripts/hermes-command check",
    "hermes:update-core": "./scripts/hermes-command update-core",
    "hermes:update-package": "./scripts/hermes-command update-package",
    "hermes:module": "./scripts/hermes-command module",
    "format": "prettier --write . && composer format:php",
    "format:check": "prettier --check .",
    "format:php": "composer format:php",
    "lint": "pnpm check",
    "lint:php": "composer lint:php"
  },
  "devDependencies": {
    "@prettier/plugin-php": "^0.22.4",
    "prettier": "^3.4.2",
    "prettier-plugin-twig-melody": "^0.4.6"
  }
}
